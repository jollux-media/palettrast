## Copy this file to `.env.local` and fill in real values.
## This file is read by local API + DB scripts.

# -----------------------------
# Database (required)
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/palettrast

# -----------------------------
# Clerk (required for auth/saved schemes)
# -----------------------------
CLERK_SECRET_KEY=sk_test_replace_me
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# -----------------------------
# Optional runtime knobs
# -----------------------------
NODE_ENV=development
LOG_LEVEL=info
